rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Current Affairs Agent Rules ---
    match /currentAffairs/{updateId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "mahesdurai8@gmail.com" && isEmailVerified())
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256
        && data.get('displayName', 'Aspirant') is string && data.get('displayName', 'Aspirant').size() <= 100
        && (data.get('studentStatus', 'school') in ['dropper', 'school'])
        && (!data.keys().hasAll(['diagnosticScores']) || (
             data.diagnosticScores is map
          && data.diagnosticScores.get('english', 0) is number
          && data.diagnosticScores.get('gk', 0) is number
          && data.diagnosticScores.get('legal', 0) is number
          && data.diagnosticScores.get('logical', 0) is number
          && data.diagnosticScores.get('quant', 0) is number
        ))
        && data.get('createdAt', request.time) is timestamp
        && data.get('updatedAt', request.time) is timestamp;
    }

    // --- User Collection Rules ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().get('email', '') == request.auth.token.email
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if (isOwner(userId) || isAdmin())
        && isValidUser(incoming())
        && (
          isAdmin() || (
            incoming().updatedAt == request.time
            && incoming().createdAt == existing().createdAt
            && incoming().email == existing().email
            && (existing().get('isPremium', false) == incoming().get('isPremium', false) || isAdmin())
          )
        );

      match /chats/{chatId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId)
          && incoming().createdAt == request.time;
      }

      match /mocks/{mockId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(mockId)
          && incoming().completedAt == request.time;
      }
    }

    // --- Global Content ---
    match /doctrines/{doctrineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
