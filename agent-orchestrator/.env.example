# Agent Orchestrator Environment Variables
# Copy this file to .env and fill in your actual API keys.

# --- Builder Agent (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Planner Agent (Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- MCP Server ---
# Path to the workspace root where generated files will be written
WORKSPACE_PATH=..

# The port the MCP server listens on (stdio transport is default, HTTP is optional)
MCP_SERVER_TRANSPORT=stdio
